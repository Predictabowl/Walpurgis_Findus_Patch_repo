Actor BubbleTrail //Bubbles for trail
{
	Height 2
	Radius 10
	Damage 0
	Speed 0
	RenderStyle Add
	Alpha 0.8
	Scale 0.27
	Gravity 0.05
	Mass 10
	+FORCEXYBILLBOARD
	+NOINTERACTION
	+DROPOFF
	+ROLLSPRITE
	+ROLLCENTER
	States
	{
	Spawn:
		TNT1 A 1 
		TNT1 A 0 A_Jump(80,"JustOne")
		TNT1 A 0 A_Jump(30,"BiggerCluster")
		TNT1 A 0 A_Jump(50,"MediumCluster")
	SmallCluster:
		BUBB LLLLLL 1 {
			A_FadeOut(0.05);
			A_SetRoll(roll-random(5,30));
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Goto JustTwo
	MediumCluster:
		BUBB MMMMMM 1 {
			A_FadeOut(0.05);
			A_SetRoll(roll-random(5,30));
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Goto SmallCluster
	BiggerCluster:
		BUBB NNNNNN 1 {
			A_FadeOut(0.05);
			A_SetRoll(roll-random(5,30));
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Goto SmallCluster
	JustTwo:
		BUBB OOO 1 {
			A_FadeOut(0.05);
			A_SetRoll(roll-random(5,30));
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Goto JustOne
	JustOne:
		BUBB PPP 1 {
			A_FadeOut(0.05);
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Goto Remnant
	Remnant:
		BUBB Q 1 {
			A_FadeOut(0.01);
			A_ChangeVelocity(random(-6,3),random(-2,2),random(-1,-3),CVF_RELATIVE);
			}
		Loop
	}
}

