ACTOR DoTheWaveDude
{
	Radius 20
	Height 20
	Speed 20
	//Damage (random(1,2))
	Damage (random(1,5))
	//Projectile
	Alpha 0.8
	XScale 1.2
	YScale 0.7
	RenderStyle Add
	DamageType "Water"
	//+FLOORHUGGER
	//+FORCEPAIN
	//+FRIENDLY
	//-DROPOFF
	DeathSound "DagonSplashBurst"
  	Mass 2000
	Gravity 1.5
	Friction 0.9
	BounceFactor 0.2
	BounceType Classic
	BounceCount 255
	+MISSILE
	-NOGRAVITY
	+SHOOTABLE
	-DROPOFF
	-NOBLOCKMAP
	+NOEXPLODEFLOOR
	+STEPMISSILE
	-FRIENDLY
	+EXTREMEDEATH
	+FORCEPAIN
	+EXPLODEONWATER
	+FORCERADIUSDMG
	+BOUNCEONFLOORS
	+BLOODLESSIMPACT
	+RIPPER
	+FRIENDLY
  States
  {
	Spawn:
		TNT1 A 3
		WD4G ABC 2 
	SurfThis:
		WD4G DEFG 2 Bright 
		{	
		A_GiveInventory("Walpurgisnacht",1);
		A_SpawnItemEx("SplashyBlob",-3,random(-2,-25),30,random(-1,-9),random(5,-5),random(3,7));
		A_SpawnItemEx("SplashyBlob",-3,random(2,25),30,random(-1,-9),random(5,-5),random(3,7));
		A_SpawnItemEx("SplashyBlob",-3,random(-2,-25),30,random(-1,-9),random(5,-5),random(3,7));
		A_SpawnItemEx("SplashyBlob",-3,random(2,25),30,random(-1,-9),random(5,-5),random(3,7));
		A_RadiusThrust(randompick(-20,-30,-25,-40,5),184,RTF_NOTMISSILE|RTF_THRUSTZ|RTF_NOIMPACTDAMAGE,160);
		
		// NEW: Spawn invisible reflecting shields to the left and right (matches the visual wave width)
		A_SpawnItemEx("WaveDeflectorShield", 0, 35, 0, 0, 0, 0, 0, 0);
		A_SpawnItemEx("WaveDeflectorShield", 0, -35, 0, 0, 0, 0, 0, 0);

		// "Pain-Lock": Rapidly forces enemies into pain state to simulate a stun
		A_Explode(1, 150, XF_NOSPLASH|XF_EXPLICITDAMAGETYPE, false, 0, 0, 0, "BulletPuff", "Water"); 
		//
		A_SpawnItemEx("BubbleTrail",-6,random(-30,30),40,-2,0,0);
		A_SpawnItemEx("BubbleTrail",-6,random(-30,30),40,-2,0,0);
		A_Setscale(frandompick(1.2,1.22,1.25,1.27,1.3)+(CountInv("Walpurgisnacht")/60.00),frandompick(0.8,0.82,0.85,0.87,0.9)-(CountInv("Walpurgisnacht")/60.0));
		//A_Explode(random(0,3),(120+CountInv("Walpurgisnacht")));
		A_Explode(random(1,6),(120+CountInv("Walpurgisnacht")));
		A_Fadeout(0.01);
		A_Setsize(radius+0.01,height-0.01,true);
		} 
		WD4G D 0 A_JumpIfInventory("Walpurgisnacht",70,"Death")
		Loop
	Death:
		WD4G DEFGHIJ 5 Bright {A_Fadeout(0.05); A_Setscale(scalex+0.1,scaley-0.1); A_SpawnItemEx("SplashyBlob",-3,random(2,25),30,random(-1,-9),random(5,-5),random(3,7));}
		Stop
  }
}

ACTOR DoTheReverseWaveDude : DoTheWaveDude //sounds painful
{
	+SPRITEFLIP
}

