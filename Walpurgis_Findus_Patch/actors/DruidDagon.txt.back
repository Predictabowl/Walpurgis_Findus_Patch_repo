ACTOR DagonsCane : DruidWeapon 23832
{
	//Water based magic as offence doesn't tend to be used too often in my
	//experience. It always becomes ice as a standard! So, Dagon's Cane is 
	//exploring that niche. Its obviously HPL Mythos inspired in this case.
	//Of course, it also gives the Druid a good ranged attack option as well.
	//The Geyser ignores elevation between you and the nearest full wall or foe,
	//so be sure to use that to your advantage, and don't underestimate
	//the utility of the charge attack to force your way through packs.
	Inventory.RestrictedTo DruidPlayer
	+BLOODSPLATTER
	+NOTAUTOAIMED
	+UNDROPPABLE
	Weapon.SelectionOrder 2
	Weapon.SlotNumber 2
	Weapon.SlotPriority 1
	Weapon.AmmoGive1 25
	Weapon.AmmoUse 2
	Weapon.AmmoType "Mana1W"
	Inventory.PickupSound "Pickup/WeaponStaff"
	Weapon.BobStyle InverseSmooth
	Weapon.BobSpeed 1.5
	Weapon.BobRangeY 0.5
	Weapon.BobRangeX 1.2
	Weapon.YAdjust -10
	Inventory.PickupMessage "\c[white]A bizarre cane \c[red]with a head of coral\c[white]. These things invoke the old gods to \c[sapphire]manipulate and create water\c[white]. [\c[blue]2\c[white]]"
	Tag "Dagon's Cane"
	Obituary "%o joined the Deep Ones."
	States
	{
	Spawn:
		DAG0 T 16
		DAG0 SRS 4 
		Loop
	Select:
		TNT1 A 1
		TNT1 A 0 A_GiveInventory("DagonInHand",1)
		TNT1 A 0 A_JumpIfInventory("ChainHook",1,"BirbCheck") //If Birb is supposed to be here, check him.
		Goto Select2
	Deselect:
		TNT1 A 0 A_TakeInventory("DagonInHand")
		TNT1 A 0 
		{
			A_TakeInventory("ComboCounter");
		}
		Goto Deselect2
	BirbCheck:
		TNT1 A 0 {A_GiveToChildren("LightningCheck",1); A_SpawnItemEx("CorvusB",0,0,40,0,0,0,0,SXF_SETMASTER);}
		Goto Select2
	Select2:
		DAG0 A 1 A_Raise
		Loop
	Deselect2:
		DAG0 A 1 A_Lower
		Loop
	Ready:
		DAG0 A 1 A_WeaponReady(WRF_ALLOWRELOAD)	
		Loop
	Fire:
		TNT1 A 0 A_JumpIfInventory("PowerAmbitMana", 1, "FireDagon1")
		DAG0 A 0 A_CheckReload
		Goto FireDagon1
	FireDagon1: 
		DAG0 B 1 A_StartSound("DagonCharge",1,CHANF_OVERLAP|CHANF_LOCAL,0.6,ATTN_STATIC,1)
		DAG0 CDE 1 
		Goto FireDagon2
	FireDagonRepeat:
		DAG0 A 0 A_CheckReload
		DAG0 N 1 A_StartSound("DagonCharge",1,CHANF_OVERLAP|CHANF_LOCAL,0.6,ATTN_STATIC,1)
		DAG0 OOE 1
	FireDagon2:
		DAG0 F 2 
		DAG0 GHIJ 2
		DAG0 K 2 {A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE); 
		if(random(1,3) == 1 && (GetCVar("walp_silentprotagonists")==0) && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExertsLight",CHAN_AUTO,CHANF_OVERLAP,1,false,ATTN_NONE);}}
		DAG0 L 2 {	if(CountInv("DagonMutate") == 1 || CountInv("DagonMutate") == 4 || CountInv("DagonMutate") == 6 || CountInv("DagonMutate") == 9)
					{
					A_StartSound("DagonAquaJet",1,CHANF_OVERLAP|CHANF_LOCAL,1,ATTN_STATIC,frandom(0.95,1.05)); 
					}
					else if(CountInv("DagonUpgrade") == 1 || CountInv("DagonUpgrade") == 4 || CountInv("DagonUpgrade") == 6 || CountInv("DagonUpgrade") == 9)
					{
					A_StartSound("DagonShots",1,CHANF_OVERLAP|CHANF_LOCAL,0.95,ATTN_STATIC,frandom(0.9,1.05)); 
					A_StartSound("DagonSteam",37,CHANF_OVERLAP|CHANF_LOCAL,0.9,ATTN_STATIC,frandom(0.9,1.05)); 
					}
					else
					{
					A_StartSound("DagonShots",1,CHANF_OVERLAP|CHANF_LOCAL,0.8,ATTN_STATIC,frandom(0.95,1.05)); 
					}
					A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);}
		DAG0 M 2 { 
				A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);
				if(CountInv("DagonUpgrade") == 1 || CountInv("DagonUpgrade") == 4 || CountInv("DagonUpgrade") == 6 || CountInv("DagonUpgrade") == 9)
				{
				A_FireCustomMissile("WaterBlastBoom",0,0,-10,3,CMF_AIMDIRECTION,0);
				A_Recoil(1);
				}
				else if(CountInv("DagonMutate") == 1 || CountInv("DagonMutate") == 4 || CountInv("DagonMutate") == 6 || CountInv("DagonMutate") == 9)
				{
				A_FireCustomMissile("AquaAquaJet",1,0,-8,3,CMF_AIMDIRECTION,0);
				A_FireCustomMissile("AquaAquaJet",-1,0,-12,0,CMF_AIMDIRECTION,0);
				A_FireCustomMissile("AquaAquaJet",0,0,-10,3,CMF_AIMDIRECTION,0);
				A_TakeInventory("Mana1W", 2,TIF_NOTAKEINFINITE);
				}
				else
				{
				A_FireCustomMissile("WaterBlast",0,0,-10,3,CMF_AIMDIRECTION); 
				A_Recoil(1);
				}
				}
		DAG0 M 0 A_Refire("FireDagonRepeat")
		DAG0 NODC 2
		Goto Ready
	AltFire:
		TNT1 A 0 A_JumpIfInventory("PowerAmbitMana", 1, "GeyserSlam1")
		TNT1 A 0 A_JumpIfInventory ("Mana1W", 4, "GeyserSlam1")
		DAG0 B 0 A_JumpIfInventory ("Mana1W", 2, "Fire")
		DAG0 B 0 A_SelectWeapon("DeliberatelyNothing",SWF_SELECTPRIORITY) //For some stupid reason A_CheckReload fails here.
		Goto Fire
	GeyserSlam1:
		DAG0 B 1 {if(random(1,7) == 1 && (GetCVar("walp_silentprotagonists")==0) && (CountInv("PowerShutItWilson")) == 0){A_StartSound("DruiExertsLight",CHAN_AUTO,CHANF_OVERLAP,1,false,ATTN_NONE);}}
		DAG1 A 1
		DAG2 A 1
		DAG2 B 1 
		Goto GeyserSlam2
	GeyserLoop:
		DAG1 C 1 A_JumpIfInventory ("Mana1W", 4, "GeyserSlam2")
		Goto GeyserSlamReturn
	GeyserSlam2:	
		DAG1 C 1 {A_StartSound("DagonCharge",1,CHANF_OVERLAP|CHANF_LOCAL,0.6,ATTN_STATIC,0.8); A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);}
		DAG1 DEFG 2 A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE)
		DAG1 H 2 {	if(GetCVar("walp_nocamera")==0)	
			{	A_SetPitch(pitch-8,SPF_INTERPOLATE);	}	
			A_StartSound("KnifeSwish2",1,CHANF_OVERLAP|CHANF_LOCAL,0.7,ATTN_STATIC,0.7); } 
		DAG1 HHII 1 {if(GetCVar("walp_nocamera")==0)	
			{A_SetPitch(pitch-8,SPF_INTERPOLATE);}}
		DAG1 J 3 {	if(GetCVar("walp_nocamera")==0)	
			{	A_SetPitch(pitch+8,SPF_INTERPOLATE);	}	
			A_StartSound("KnifeSwish2",1,CHANF_OVERLAP|CHANF_LOCAL,0.7,ATTN_STATIC,0.6); } 
		DAG1 K 0 {if(random(1,4) >= 2 && (GetCVar("walp_silentprotagonists")==0) && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExerts",CHAN_AUTO,CHANF_OVERLAP,0.9,ATTN_NONE,frandom(0.97,1.04));}}
		DAG1 KKLL 1 {if(GetCVar("walp_nocamera")==0)	
			{A_SetPitch(pitch+8,SPF_INTERPOLATE);}}
		DAG1 M 2 {
				if(CountInv("DagonUpgrade") == 3 || CountInv("DagonUpgrade") == 4 || CountInv("DagonUpgrade") == 8 || CountInv("DagonUpgrade") == 9)
				{
				A_FireProjectile("GeyserCreatorPower",0,false,0,0,FPF_NOAUTOAIM,3); 
				}
				else if(CountInv("DagonMutate") == 3 || CountInv("DagonMutate") == 4 || CountInv("DagonMutate") == 8 || CountInv("DagonMutate") == 9)
				{
				A_FireProjectile("WhirlpoolCreatorPower",0,false,0,0,FPF_NOAUTOAIM,3); 
				}
				else
				{
				A_FireProjectile("GeyserCreator",0,false,0,0,FPF_NOAUTOAIM,3); 
				}
				A_StartSound("DagonGeyser",1,CHANF_OVERLAP|CHANF_LOCAL,0.8,ATTN_STATIC,1.1);}
		DAG1 NOD 2
		DAG1 C 1 A_Refire("GeyserLoop")
	GeyserSlamReturn:
		DAG2 A 1 
		DAG1 A 1
		DAG0 B 1
		Goto Ready
	Reload:	 
		DAG0 B 0 A_JumpIfInventory("PowerAmbitMana", 1, "PrepAquaCharge")
		DAG0 B 0 A_JumpIfInventory ("Mana1W", 4, "PrepAquaCharge")
		DAG0 B 0 A_JumpIfInventory ("Mana1W", 2, "Fire")
		DAG0 B 0 A_SelectWeapon("DeliberatelyNothing",SWF_SELECTPRIORITY) //For some stupid reason A_CheckReload fails here.
		Goto Fire
	PrepAquaCharge:
		DAG0 B 2
		DAG1 A 2 
		DAG1 B 2 {if(random(1,5) >= 2 && (GetCVar("walp_silentprotagonists")==0) && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExertsHeavy",CHAN_AUTO,CHANF_OVERLAP,0.9,ATTN_NONE,frandom(0.97,1.04));}}
	AquaCharge:
		DAG2 CD 2 A_StartSound("BewChargeA",CHAN_AUTO,CHANF_OVERLAP,1.2,false,ATTN_NONE)
		DAG2 EFGH 1 A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE)
		DAG2 I 2 A_SetBlend("White",0.2,2)
		DAG2 J 1 {A_SetBlend("White",0.6,35); A_StartSound("SStaff",CHAN_AUTO,CHANF_OVERLAP,1.2,false,ATTN_NONE);}
		DAG2 J 1 {	if(CountInv("DagonMutate") == 5 || CountInv("DagonMutate") == 6 || CountInv("DagonMutate") == 8 || CountInv("DagonMutate") == 9)
					{
					A_FireProjectile("DoTheWaveDude",0,false,-40,0,FPF_NOAUTOAIM,3);
					A_FireProjectile("DoTheWaveDude",0,false,0,0,FPF_NOAUTOAIM,3);
					A_FireProjectile("DoTheReverseWaveDude",0,false,40,0,FPF_NOAUTOAIM,3);
					A_GiveInventory("CoptersSound",1);
					}
					else
					{
					A_Overlay(-23,"WashedUp"); 
					A_OverlayFlags(-23,PSPF_ADDBOB|PSPF_ADDWEAPON,true);
					}}
	AquaChargeLooper:
		DAG2 P 0 A_JumpifInventory("CoptersSound",1,"AquaChargeEnd")
		DAG2 P 1 
		Loop
	AquaChargeEnd:
		DAG2 K 1 A_TakeInventory("CoptersSound")
		DAG2 LB 1
		Goto Ready	
	WashedUp: //This overlay actually does most of the tertiary Aqua-Charge fire code!
		W4ZO A 0 {
		A_AlertMonsters; 
		A_ChangeFlag("INVULNERABLE", TRUE);
		A_ChangeFlag("NODROPOFF", TRUE); 
		A_ChangeFlag("THRUACTORS", TRUE);
		A_ChangeVelocity(61,0,0,CVF_RELATIVE|CVF_REPLACE); 
		//A_FireProjectile("DecorativeWave",0,false,0,0,FPF_NOAUTOAIM,0);
		A_SpawnItemEx("DecorativeWave",42,2,0,64,0,0);
		}
		W4ZO ABCDEABCDE 1 	{
		if(CountInv("DagonUpgrade") == 5 || CountInv("DagonUpgrade") == 6 || CountInv("DagonUpgrade") == 8 || CountInv("DagonUpgrade") == 9)
				{
				A_Explode(random(16,((velx)+15)),240,0,true,200,0,0,"None","Water"); 
				A_ChangeVelocity(8,0,0,CVF_RELATIVE);	
				}
				else
				{
				A_Explode(random(12,((velx/1.5)+11)),204,0,true,184,0,0,"None","Water"); 
				A_ChangeVelocity(6,0,0,CVF_RELATIVE);
				}
		A_SpawnItemEx("WhirlpoolTrail",44,0,48,-2,0,0);
		A_SpawnItemEx("WhirlpoolTrail",36,0,48,-2,0,0);
		A_SpawnItemEx("SplashyBlob",random(60,78),randompick(-20,-30,-40),random(42,52),random(4,10),0,-1);
		A_SpawnItemEx("SplashyBlob",random(60,78),randompick(20,30,40),random(42,52),random(4,10),0,-1);
		A_SpawnItemEx("BubbleTrail",random(60,78),random(10,40),random(42,52),3,0,1);
		A_SpawnItemEx("BubbleTrail",random(60,78),random(-10,-40),random(42,52),3,0,1);
							}
		W4ZO E 0 {A_ChangeVelocity(9,0,0,CVF_RELATIVE|CVF_REPLACE); 
		A_ChangeFlag("NODROPOFF", FALSE); 
		A_ChangeFlag("THRUACTORS", FALSE); 
		A_ChangeFlag("INVULNERABLE", FALSE);
		A_Blast(BF_AFFECTBOSSES|BF_NOIMPACTDAMAGE,255,255,30,"RushSplash","DagonSplashBurst");
		A_GiveInventory("CoptersSound",1);}
		Stop
	}
}

Actor WaterBlast : FastProjectile //JT- Fired by Dagon's Cane Primary
{
	Radius 10
	Height 6
	Damage (0) //(random(80,140)+random(2,8))
	Damagetype "Water"
	Alpha 0.8
	XScale 0.33
	YScale 0.33
	Renderstyle Add //Translucent
	Projectile
	MissileType "BubbleTrail" 
	MissileHeight 8
	Mass 50
	//Decal "SerpentScorch"
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	//+MTHRUSPECIES 
	+DONTBLAST
	+ROLLSPRITE
	+ROLLCENTER
	+HITTRACER
	Speed 85
	DeathSound "DagonSplashBurst"
	States
	{
	Spawn:
		W4B4 L 0 Nodelay 
		//W4SS ABCD 1 {A_SetRoll(roll+15); A_Setscale(scalex+0.05,scaley+0.05);}
	Spawn2:
		W4B4 L 1 {A_SetRoll(roll+40);}
		Loop
	Death:
		W4SS E 0 
		{
		A_Setscale(scalex+0.3,scaley+0.3);
		A_Stop;
		A_Explode(random(80,125)+random(2,8),110,XF_THRUSTZ,true,85,0,0,"None","Water");
		A_SpawnProjectile("SplashyBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SplashyBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		W4SS EDFGHIJ 2 
		{
		A_SetRoll(roll+33); 
		A_SpawnProjectile("SplashyBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SplashyBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		Stop
	}
}

Actor WaterBlastSmol  //Mutated Primary
{
	Radius 7
	Height 5
	Damage (0) 
	Damagetype "Water"
	Alpha 0.8
	XScale 0.2
	YScale 0.2
	Renderstyle Add //Translucent
	Projectile
	Mass 60
	Gravity 1.4
	-NOGRAVITY	//Has dropoff
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	//+MTHRUSPECIES 
	+DONTBLAST
	+ROLLSPRITE
	+ROLLCENTER
	+HITTRACER
	Speed 55
	DeathSound "DagonSplashBurstQuieter"
	States
	{
	Spawn:
		W4B4 L 0 Nodelay 
		//W4SS ABCD 1 {A_SetRoll(roll+15); A_Setscale(scalex+0.05,scaley+0.05);}
	Spawn2:
		W4B4 L 1 {A_SetRoll(roll+40); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3));}
		Loop
	Death:
		W4SS E 0 
		{
		A_Setscale(scalex+0.3,scaley+0.3);
		A_Stop;
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		A_Explode (random(5,25), 70, 0, 0, 60,0,0,"None","Water");
		}
		W4SS EDFGHIJ 2 
		{
		A_SetRoll(roll+33); 
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		Stop
	}
}


Actor AquaAquaJet  //Mutated Primary
{
	Radius 7
	Height 5
	Damage (random(5,30)) 
	Damagetype "Water"
	Alpha 0.8
	XScale 0.2
	YScale 0.2
	Renderstyle Add //Translucent
	Projectile
	MissileType "SmallSplosh" 
	MissileHeight 8
	Mass 60
	BounceType Grenade
	BounceCount 3
	BounceFactor 1
	WallBounceFactor 0.4
	Gravity 1.4
	-NOGRAVITY	//Has dropoff
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	+DONTBLAST
	+ROLLSPRITE
	+ROLLCENTER
	+HITTRACER
	+USEBOUNCESTATE
	+BOUNCEONACTORS
	Speed 45
	DeathSound "DagonSplashBurst"
	States
	{
	Spawn:
		W4B4 L 0 Nodelay 
		//W4SS ABCD 1 {A_SetRoll(roll+15); A_Setscale(scalex+0.05,scaley+0.05);}
	Spawn2:
		W4B4 L 0 A_JumpIfInventory("Walpurgisnacht",15,"Death")
		W4B4 L 1 {A_SetRoll(roll+40); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3)); 
		A_SpawnItemEx("SmallSplosh",-1,0,0,-2,random(3,-3),random(3,-3));}
		Loop
	Bounce:
		W4B4 L 0 
		{
			A_GiveInventory("Walpurgisnacht",5); 
			A_Explode ((random(15,30)-(CountInv("Walpurgisnacht"))), 90, 0, 0, 70,0,0,"None","Water");
			A_SpawnItemEx("WaterBlastSmol",-10,0,0,Random(-5,5),Random(-5,5),frandom(7,15));
			A_StartSound("DShotBurst4",CHAN_AUTO,CHANF_OVERLAP,0.8,ATTN_NORM,frandom(1.1,1.4));	
		}
		Goto Spawn
	Bounce.Floor:
		W4B4 L 0
		{
			A_GiveInventory("Walpurgisnacht",5); 
			A_Explode ((random(15,30)-(CountInv("Walpurgisnacht"))), 90, 0, 0, 70,0,0,"None","Water");
			A_SpawnItemEx("WaterBlastSmol",-10,0,0,Random(-5,5),Random(-5,5),frandom(7,15));
			ThrustThingZ(0,20,0,1);
			ThrustThing(angle*256/360,6,0,0);
			A_StartSound("DShotBurst4",CHAN_AUTO,CHANF_OVERLAP,0.8,ATTN_NORM,frandom(1.1,1.4));	
		}
		Goto Spawn
	Bounce.Wall:
		W4B4 L 0
		{
			A_GiveInventory("Walpurgisnacht",5); 
			A_Explode ((random(15,30)-(CountInv("Walpurgisnacht"))), 90, 0, 0, 70,0,0,"None","Water");
			A_SpawnItemEx("WaterBlastSmol",-10,0,0,Random(-5,5),Random(-5,5),frandom(7,15));
			ThrustThing(angle*256/360 + 128,6,0,0);
			A_StartSound("DShotBurst4",CHAN_AUTO,CHANF_OVERLAP,0.8,ATTN_NORM,frandom(1.1,1.4));	
		}
		Goto Spawn
	Bounce.Actor:
		W4B4 L 0
		{
			A_Stop;
			A_GiveInventory("Walpurgisnacht",5); 
			A_Explode ((random(15,30)-(CountInv("Walpurgisnacht"))), 90, 0, 0, 70,0,0,"None","Water");
			A_SpawnItemEx("WaterBlastSmol",-10,0,0,Random(-5,5),Random(-5,5),frandom(7,15));
			ThrustThingZ(0,30,0,1);
			ThrustThing((angle*256/360)+randompick(128,128,128,128,64,192),20,1,0);
			A_StartSound("DShotBurst4",CHAN_AUTO,CHANF_OVERLAP,0.8,ATTN_NORM,frandom(1.1,1.4));	
		}
		Goto Spawn
	Death:
		W4SS E 0 
		{
		A_Setscale(scalex+0.3,scaley+0.3);
		A_Stop;
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		W4SS EDFGHIJ 2 
		{
		A_SetRoll(roll+33); 
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("SmallSplosh",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		Stop
	}
}

Actor WaterBlastBoom : FastProjectile //Upgraded Dagon Primary
{
	Radius 10
	Height 6
	Damage (0) //(random(80,140)+random(2,8))
	Damagetype "Water"
	Alpha 0.8
	XScale 0.33
	YScale 0.33
	Renderstyle Add //Translucent
	Projectile
	MissileType "BubbleTrail" 
	MissileHeight 8
	Mass 50
	//Decal "SerpentScorch"
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	//+MTHRUSPECIES 
	+DONTBLAST
	+ROLLSPRITE
	+ROLLCENTER
	+HITTRACER
	Speed 95
	DeathSound "DagonSplashBurst"
	States
	{
	Spawn:
		W4B4 L 0 Nodelay 
		//W4SS ABCD 1 {A_SetRoll(roll+15); A_Setscale(scalex+0.05,scaley+0.05);}
	Spawn2:
		W4B4 L 1 {	A_SetRoll(roll+40);
					A_SpawnItemEx("WhirlpoolTrail",-2,0,0,-8,0,0);
					A_SpawnItemEx ("SmokyAlabaster",0,0,6,0,0,1);
					}
		Loop
	Death:
		W4SS E 0 
		{
		A_Setscale(scalex+0.3,scaley+0.3);
		A_Stop;
		A_Explode(random(80,145)+random(2,8),110,XF_THRUSTZ,true,85,0,0,"None","Water");
		A_SpawnItemEx("WallBallBoomRight",-4,6,-34,0,0,0);
		A_SpawnItemEx("WallBallBoomLeft",-4,-6,-34,0,0,0);
		//A_ChangeVelocity (-5,0,2,CVF_RELATIVE,AAPTR_TRACER); // ORIGINAL
		if(A_CheckFlag("ISMONSTER", "Null", AAPTR_TRACER)) { A_ChangeVelocity (-5,0,2,CVF_RELATIVE,AAPTR_TRACER); }
		A_SpawnProjectile("GeyserBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("GeyserBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		W4SS EDFGHIJ 2 
		{
		A_SetRoll(roll+33); 
		A_SpawnProjectile("GeyserBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-18,12));
		A_SpawnProjectile("GeyserBlob",0,0,random(0,360),CMF_AIMDIRECTION,random(-12,18));
		}
		Stop
	}
}

