				A_SpawnProjectile("GeyserBlob",random(50,62),0,random(0,360),CMF_AIMDIRECTION,random(-55,-75));
				A_SpawnProjectile("GeyserBlob",random(50,62),0,random(0,360),CMF_AIMDIRECTION,random(-65,-90));
				A_SpawnItemEx("GeyserBlur", 0, 0, 0, 0, 0, 0, 0, SXF_TRANSFERSPRITEFRAME);
				A_Explode(random(6,9),120,XF_THRUSTZ,true,85,0,0,"None","Water");
						 }
		Stop
	Death:
		TNT1 A 1
		Stop 
	} 
}

