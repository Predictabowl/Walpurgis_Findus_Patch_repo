		WD4G F 0 A_Stop
		WD4G EFGHIJ 3 Bright {A_Fadeout(0.05); A_Setscale(scalex+0.1,scaley-0.1); A_SpawnItemEx("SplashyBlob",-3,random(2,25),30,random(-1,-9),random(5,-5),random(3,7));}
		Stop
  }
}