ACTOR WishyWashyWaterWhirl : HeadFX3 //Mutated Secondary
{
	Renderstyle Add
	XScale 0.4
	YScale 1.2
	Alpha 0.8
	Radius 1
	Height 1
	Damagetype "Water"
	Species "Whirlpool"
	+THRUSPECIES
	States
	{
	Spawn:
		TNT1 A 1 Nodelay A_Setscale(scalex+((CountInv("Walpurgisnacht"))/6.0),scaley)
	NoGrow:
		W0P0 ABCDEFGHIJKL 2 Bright {
				A_SpawnProjectile("GeyserBlob",random(30,52),0,random(0,360),CMF_AIMDIRECTION,random(-45,-60));
				A_SpawnProjectile("GeyserBlob",random(30,52),0,random(0,360),CMF_AIMDIRECTION,random(-45,-60));
				A_QuakeEx(3,3,8,20,100,40,"-",QF_WAVE);
				A_RadiusThrust(randompick(-20,-30,-25,-40,5),184,RTF_NOTMISSILE|RTF_THRUSTZ|RTF_NOIMPACTDAMAGE,160);
				A_Explode(random(2,7),120,XF_THRUSTZ,true,95,0,0,"None","Water");
				}
	Death:
		W0P0 MNO 2 Bright {A_Fadeout(0.1); A_Setscale(scalex+0.05,scaley+0.05);}
		Stop
  }
}

