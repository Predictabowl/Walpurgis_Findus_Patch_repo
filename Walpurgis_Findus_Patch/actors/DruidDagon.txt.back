ACTOR GeyserCreator //Super-Fast targeting missile
{
  Radius 5
  Height 6
  Speed 3000
  Damage (random(20,30))
  Projectile
  Alpha 0
  RenderStyle Add
  DamageType "Water"
  +FLOORHUGGER
  +FORCEPAIN
  +FRIENDLY
  +SEEKERMISSILE
  +HITTRACER
  DeathSound "DagonSplashBurst"
  States
  {
  Spawn:
		TNT1 A 1 
		{	
			A_SeekerMissile(30,35,SMF_LOOK|SMF_PRECISE,128,1);
		}
		Loop
  XDeath:
	    TNT1 A 2  {	
				A_SpawnItemEx("PressureGeyser",0,0,0,0,0,0);
				A_SpawnItemEx("GeyserFissures");
				//A_ChangeVelocity (-1,-0,12,CVF_RELATIVE,AAPTR_TRACER);} //halts enemy velocity so they get hit by geyser // ORIGINAL
				if(A_CheckFlag("ISMONSTER", "Null", AAPTR_TRACER)) { A_ChangeVelocity (-1,-0,12,CVF_RELATIVE,AAPTR_TRACER); }} //halts enemy velocity so they get hit by geyser
		Stop
  Death:
		TNT1 A 2  {	
				A_SpawnItemEx("MovingGeyser",-30,0,0,-2,0,0); //if it hits a wall, moves away slightly to reduce clipping
				A_SpawnItemEx("GeyserFissures");
				//A_ChangeVelocity (-1,-0,12,CVF_RELATIVE,AAPTR_TRACER);} // ORIGINAL
				if(A_CheckFlag("ISMONSTER", "Null", AAPTR_TRACER)) { A_ChangeVelocity (-1,-0,12,CVF_RELATIVE,AAPTR_TRACER); }}
		Stop
  }
}

