			Stop
	}
}

Actor FireSpiralIchival
{
	+NOINTERACTION
	+DONTBLAST
	Reactiontime 15
	Height 1
	Radius 1
	SeeSound "FireWhipping"
	DamageType "Blast"
	States
	{
	Spawn:
		TNT1 A 0 Nodelay {A_SpawnItemEx("FireSpiralIchivalReverse",30,0,0,velx,vely,velz,0,SXF_TRANSFERPOINTERS|SXF_ORIGINATOR|SXF_SETMASTER); A_StartFire;}
	Spawn2:
		TNT1 A 0 A_SetAngle(angle+15)
		TNT1 A 0 A_ChangeVelocity(3,3,3,CVF_RELATIVE|CVF_REPLACE)
		TNT1 A 1 A_SpawnItemEx("FireSpiralIchivalEffect",0,0,0)
		TNT1 A 0 {A_CountDown; A_Fire;}
		Loop
	Death:
		TNT1 A 0 A_Startsound("vile/firecrkl",0,CHANF_OVERLAP,1,ATTN_IDLE)
		Stop
	}
}

