ACTOR BounceArrow //Bouncing-Blazer, the Tertiary fire.
{ 
	Obituary "%o was burned alive by %k's purification arrows." 
	Radius 7 
	Height 6 
	Speed 99
	Scale 1.1
	Damage (5)
	Damagetype "Blast"
	Renderstyle Add
	Bouncetype Grenade
	Projectile
	BounceFactor 0.95
	WallBounceFactor 0.95
	BounceCount 12
	Bouncesound "BounceFire"
	Deathsound "BallExplod"
	Decal "SerpentScorch"
	Species "Ichival"
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	+MTHRUSPECIES 
	+DONTBLAST
	+USEBOUNCESTATE
	+ALLOWBOUNCEONACTORS
	+BOUNCEONACTORS
	+SEEKERMISSILE
	alpha 1.0
	SeeSound "CruxShots"
	States 
	{ 
	Spawn:
		LARO A 1 Bright {A_SpawnItemEx("FlameTh",0,0,0,-2,random(3,-3),random(3,-3)); A_SpawnItemEx("FlameTh",0,0,0,-2,random(3,-3),random(3,-3)); A_SeekerMissile(10, 13);}
		Loop
	//Bounce.Actor.Creature:
		//LARO A 0 Bright {
		//				A_Explode(random(20,40)+random(2,8),66,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Blast");
		//Goto Spawn
	Bounce:
		LARO A 0 Bright { 
				A_SpawnItemEx ("MIRVClusterIchival",0,0,0,Random(5,15),Random(-5,5),Random(10,18),0);
				A_SeekerMissile(90, 90);
						}
		Goto Spawn
	Death: 
		YGLW A 0 
		{
		A_Stop;
		A_Explode(random(20,40)+random(2,8),212,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Blast");
		A_SetScale(1.2,1.2);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		}
		YGLW AAAAAAAAAAA 2 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}
		Stop
	} 
}

