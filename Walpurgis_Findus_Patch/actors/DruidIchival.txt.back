ACTOR ButterflyShot : FastProjectile //No longer used, it was a bit shit.
{
	Obituary "%o was burned alive by %k's purification arrows." 
	Radius 7 
	Height 6 
	Speed 132
	Scale 1.1
	Damagetype "Sacred"
	MissileType "SunProjectileTrail" 
	MissileHeight 8
	Renderstyle Add
	Projectile
	//Decal "SerpentScorch"
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	+MTHRUSPECIES 
	+DONTBLAST
	alpha 1.0
	SeeSound "CruxShots"
	States 
	{ 
	Spawn:
		LARO A 1 Bright 
		Loop
	Crash:
		YGLW A 0 A_ChangeFlag("NOCLIP",true)
		YGLW A 0 A_Stop
		YGLW A 0 A_SpawnItemEx("BFSpawner",0,0,80,0,0,0,0,SXF_ORIGINATOR|SXF_SETMASTER )
		YGLW AAAAA 1 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}	
		Stop
	XDeath:
		YGLW A 0 A_ChangeFlag("NOCLIP",true)
		YGLW A 0 A_Stop
		YGLW A 0 A_SpawnItemEx("BFSpawner",0,0,60,0,0,0,0,SXF_ORIGINATOR|SXF_SETMASTER )
		YGLW AAAAA 1 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}	
		Stop
	Death:
		YGLW A 0 A_ChangeFlag("NOCLIP",true)
		YGLW A 0 A_SpawnItemEx("BFSpawner",-35,0,60,-2,0,0,0,SXF_ORIGINATOR|SXF_SETMASTER ) //If it dies against a wall/floor, moves a bit to reduce clipping sprites
		YGLW AAAAA 1 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}	
		Stop	
	}	
}

Actor BFSpawner //No longer used. Spawns Butterflies
{
	radius 0
	height 0
	damage 0
	speed 0
	+NOCLIP
	+DROPOFF
	+FLOORCLIP
	+NOBLOCKMAP
	+DONTBLAST
	+FRIENDLY
	States
	{
	Spawn:
		TNT1 AA 1 
	Death:
		TNT1 A 0 
		TNT1 A 1
		{
			A_ChangeFlag("NOGRAVITY", TRUE);
			While(CountInv("Mana1") < 36)
			{	//Spawns a bunch of explosion effect things
				A_SpawnItemEx("BrightestButterfly",random(15,30),0,Random(1,30),Random(1,2),0,Random(1,2),20*CountInv("Mana1"),SXF_ORIGINATOR|SXF_SETMASTER );
				A_GiveInventory("Mana1",1);
			}
		}	
		Stop
	}
}	

ACTOR BrightestButterfly //Shoddy fucking targeting sometimes... can't figure out why...
{
	Radius 4
	Height 4
	Speed 24
	Damage 12
	DamageType "Blast"
	Projectile
	Species "Playerally"
	Bouncetype "Hexen"
	BounceCount 2
	BounceFactor 0.05
	+FRIENDLY
	+MISSILE
	+FORCEXYBILLBOARD
	+NOTIMEFREEZE
	+SEEKERMISSILE
	//+SCREENSEEKER
	+THRUSPECIES
	+MTHRUSPECIES
	//+LOOKALLAROUND
	+ROLLSPRITE
	+ROLLCENTER
	Scale 0.1
	Renderstyle Add
	Alpha 0.8
	States
	{
	Spawn:
		BFLY Z 0 Nodelay {
		A_ChangeVelocity(random(-4,4),random(-4,4),random(-1,2),CVF_RELATIVE|CVF_REPLACE); 
		A_FaceMovementDirection;
		A_Setroll(roll+random(-2,2));
		}
		BFLY ZYXY 3 Bright 
		BFLY Z 0 A_GiveInventory("CoptersSound",1)
		BFLY Z 0 A_JumpIfInventory("CoptersSound",6,"Hunterkiller") 
		Loop
	Hunterkiller:
		BFLY Z 0 {
		A_ChangeVelocity(random(-4,4),random(-4,4),random(-1,2),CVF_RELATIVE|CVF_REPLACE); 
		A_Setroll(roll+random(-2,2));
		A_LookEx(LOF_NOSEESOUND,0,0,0,360,"Intercept");
		}
		BFLY Z 2 A_LookEx(LOF_NOSEESOUND,0,0,0,270,"Intercept")
		BFLY Z 1 A_SetAngle(angle+20)
		BFLY Y 2 A_LookEx(LOF_NOSEESOUND,0,0,0,270,"Intercept")
		BFLY Y 1 A_SetAngle(angle+20)
		BFLY X 2 A_LookEx(LOF_NOSEESOUND,0,0,0,270,"Intercept")
		BFLY X 1 A_SetAngle(angle+20)
		BFLY Y 2 A_LookEx(LOF_NOSEESOUND,0,0,0,270,"Intercept")
		BFLY Y 1 A_SetAngle(angle+20)
		Loop
	Intercept:
		BFLY Z 0 {
		A_Facetarget(0,180,random(-2,2),random(-2,2),FAF_BOTTOM);
		//A_ChangeVelocity(random(20,36),0,0,CVF_RELATIVE|CVF_REPLACE);
		//A_LookEx(LOF_NOSEESOUND,0,0,0,360,"Intercept");
		A_Setroll(roll+random(-2,2));
		A_SeekerMissile(90,45,SMF_PRECISE|SMF_LOOK,256,750);
		}
		BFLY ZYXY 3 Bright A_SeekerMissile(180,45,SMF_PRECISE|SMF_LOOK,256,750)
		BFLY Z 0 A_CheckRange(650,"Hunterkiller")
		Loop
	Death:
		BFLY V 0 A_Explode(6+random(2,8),60,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,60,0,0,"None","Blast")
		BFLY VVVV 2 {A_Fadeout(0.2); A_Setscale(scalex+0.3,scaley+0.3);}
		stop
	}
}

