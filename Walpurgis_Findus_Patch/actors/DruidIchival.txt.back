ACTOR MirvBombsIchival	//Remade version of Bloodscourge ones
{
	Damage (0)
	Speed 10
	Radius 1
	Scale 0.6
	Gravity 5
	Projectile
	DamageType "Blast"
	-NOGRAVITY
	//+FOILINVUL
	//+RIPPER
	+FORCERADIUSDMG
	+BLOODLESSIMPACT
	+NOTIMEFREEZE
	+THRUACTORS
	Bouncetype Grenade
	BounceFactor 0.2
	WallBounceFactor 0.2
