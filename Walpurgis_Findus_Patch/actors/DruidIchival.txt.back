ACTOR Ichival : DruidWeapon
{
	//The Ichival is originally a divine bow used by Ulir blooded characters in
	//Fire Emblem 4 on the SNES. I've actually used it a few times in my D&D
	//settings as well. I liked making the sprite for this.
	//It went through quite a revision for 0.91 though as I wasn't happy with
	//its firemodes very much... and now its pretty badass!
	Inventory.RestrictedTo DruidPlayer
	Health 3
	Weapon.SelectionOrder 1
	Weapon.SlotNumber 4
	Weapon.SlotPriority 0
	Weapon.AmmoType1 "Mana1W"
	Weapon.AmmoType2 "Mana2W"
	//Weapon.AmmoUse1 8 // Original line
	//Weapon.AmmoUse2 8 // Original line
	Weapon.AmmoUse1 5
	Weapon.AmmoUse2 5
	Weapon.AmmoGive1 25
	Weapon.AmmoGive2 25
	Weapon.YAdjust 10
	Weapon.BobStyle InverseSmooth
	Weapon.BobSpeed 2.1
	Weapon.BobRangeY 0.4
	Weapon.BobRangeX 0.5
	+BLOODSPLATTER
	+NOTAUTOAIMED
	+UNDROPPABLE
	//+WEAPON.NOALERT
	+WEAPON.PRIMARY_USES_BOTH
	Inventory.PickupSound "WeaponBuild"
	Inventory.PickupMessage "\c[white]Created The \c[gold]'Ichival'\c[white]: the Bow of the Brightest Butterfly! [\c[yellow]4\c[white]]"
	Tag "The Ichival"
	Obituary "%o was incinerated by the power of the Brightest Butterfly."
	States
	{
	Spawn:
		IC1V L -1 Bright
		Stop
	Select:
		TNT1 A 1
		TNT1 A 0 A_GiveInventory("IchivalInHand",1)
		TNT1 A 0 A_JumpIfInventory("ChainHook",1,"BirbCheck") //If Birb is supposed to be here, check him.
		Goto Select2
	Deselect:
		TNT1 A 0 A_TakeInventory("IchivalInHand")
		TNT1 A 0 
		{
			A_TakeInventory("ComboCounter");
			A_TakeInventory("BowCharge");
			A_Stopsound(7);
		}
		Goto Deselect2
	Select2:
		IBEW A 1 A_Raise
		Loop
	BirbCheck:
		TNT1 A 0 {A_GiveToChildren("LightningCheck",1); A_SpawnItemEx("CorvusB",0,0,40,0,0,0,0,SXF_SETMASTER);}
		Goto Select2
	Deselect2:
		IBEW A 1 A_Lower
		Loop
	Ready:
		IBEW A 0 A_JumpIfInventory("BowCharge", 1, "Ready2")
		IBEW A 1 A_WeaponOffset(0,24,WOF_INTERPOLATE)
		IBEW A 1 A_WeaponOffset(0,16,WOF_INTERPOLATE)
		IBEW A 1 A_WeaponOffset(0,8,WOF_INTERPOLATE)
		IBEW A 1 {A_WeaponOffset(0,0,WOF_INTERPOLATE); A_GiveInventory("BowCharge",1);}
	Ready2:
		IBEW ABCDEFG 4 {A_WeaponReady(WRF_ALLOWRELOAD); A_WeaponOffset(0,0);}	
		Loop
	Fire:
		//IBEW A 0 A_JumpIfInventory("Mana1W", 8, "FireCheck") // Original line
		IBEW A 0 A_JumpIfInventory("Mana1W", 5, "FireCheck")
		IBEW A 0 A_Checkreload
		IBEW A 0 A_WeaponOffset(0,0)
		Goto Ready
	FireCheck:
		//IBEW A 0 A_JumpIfInventory("Mana2W", 8, "FireSetup") // Original line
		IBEW A 0 A_JumpIfInventory("Mana2W", 5, "FireSetup")
		IBEW A 0 A_Checkreload
		Goto Ready
	FireSetup:
		IBEW A 0 A_PlaySound("IchiString",CHAN_6,1.6,false,ATTN_NORM,false,0.9)
		Goto FireArrow
	FireArrow:
		IBEW A 0 {A_PlaySound("LBRecharge",CHAN_5,1.1,false,ATTN_NORM,false,0.9); A_WeaponOffset(0,0);}
		//IBEW IJKLNOPQ 2 {A_TakeInventory("Mana2W", 1,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);} // Original line
		IBEW IJKLN 2 {A_TakeInventory("Mana2W", 1,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);}
		IBEW OPQ 2
		IBEW R 0 A_Playsound("LBLoop",CHAN_7,0.4,true,ATTN_NONE,false,0.9)
	FireHold:
		IBEW R 2 
		IBEW R 0 A_JumpIf((CountInv("MaceChargeCheck1") ==1),"FireZoom")
		IBEW R 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireHold2")
		Goto FireRelease
	FireHold2:
		IBEW S 2 
		IBEW S 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireHold3")
		Goto FireRelease
	FireHold3:
		IBEW T 2 
		IBEW T 0 {if(CountInv("Walpurgisnacht") < 7) //This counts how long you hold. At 48 tics (1.3 secs)
				  {									 //You go into time-slowing zoom mode.
					if(CountInv("IchivalUpgrade") == 1 || CountInv("IchivalUpgrade") == 4 || CountInv("IchivalUpgrade") == 6 || CountInv("IchivalUpgrade") == 9)
					{A_GiveInventory("Walpurgisnacht",2);} //However, if upgraded, you zoom twice as fast!
					else
					{A_GiveInventory("Walpurgisnacht",1);} } 
				  else if(CountInv("Walpurgisnacht") >= 7)
				  {A_GiveInventory("MaceChargeCheck1",1); A_GiveInventory("Walpurgisnacht",1);}
				  else
				  {}
				  }
		IBEW T 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireHold")
		Goto FireRelease
	FireZoom:
		Z00M P 2 {	A_ZoomFactor(1.33); 					//The Zoom is pretty complex; as it involves
					A_TakeInventory("MaceChargeCheck1"); 	//the time slow power, the tunnel vision
					A_Overlay(23,"ZoomOverlays");			//overlay, and the deep breath SFX all at once. 
					A_OverlayFlags(23,PSPF_ADDWEAPON,false);
					A_StartSound("Concentrate",CHAN_6,CHANF_OVERLAP|CHANF_UI,1.3,false,ATTN_NONE);
					}
		Z00M P 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoom2")
		Goto FireReleaseZ
	FireZoom2:
		Z00M Q 2 Offset(3,35) A_ZoomFactor(1.66)
		Z00M Q 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoom3")
		Goto FireReleaseZ
	FireZoom3:
		Z00M R 2 Offset(6,35) A_ZoomFactor(2)
		Z00M R 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoomHold2")
		Goto FireReleaseZ
	FireZoomHold:
		Z00M R 2 Offset(9,35) A_GiveInventory("IchivalPower", 1)
		Z00M R 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoomHold2")
		Goto FireReleaseZ
	FireZoomHold2:
		Z00M S 2 Offset(9,35)
		Z00M S 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoomHold3")
		Goto FireReleaseZ
	FireZoomHold3:
		Z00M T 2 Offset(9,35) 
		Z00M T 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ATTACK),"FireZoomHold")
		Goto FireReleaseZ
	FireReleaseZ:
		Z00M U 1 Offset(5,33) {A_TakeInventory("PowerFocusBreath"); A_TakeInventory("IchivalPower"); A_TakeInventory("PowerTimeFreezer");}
		Z00M U 1 Offset(5,33) {A_Stopsound(7); A_ZoomFactor(1); A_GiveInventory("MaceChargeCheck2",1); A_GiveInventory("IchivalPowerEnd",1);}
		Goto FireRelease2
	FireRelease:
		IBEW U 2 {A_Stopsound(7); 
		if(GetCVar("walp_silentprotagonists")==0 && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExerts",CHAN_AUTO,CHANF_OVERLAP,0.9,ATTN_NONE,frandom(0.97,1.04));}}
	FireRelease2:
		IBEW W 1 Offset(0,32) {A_SetBlend("Yellow",0.4,20); A_TakeInventory("PowerFocusBreathEnd"); A_TakeInventory("PowerTimeFreezer");}
		IBEW W 1 {
				if(CountInv("IchivalUpgrade") == 1 || CountInv("IchivalUpgrade") == 4 || CountInv("IchivalUpgrade") == 6 || CountInv("IchivalUpgrade") == 9)
				{
				A_FireProjectile("LightArrowPlus", 0, 0, 0, 2, FPF_NOAUTOAIM,0);		
				}
				else
				{
				A_FireProjectile("LightArrow", 0, 0, 0, 2, FPF_NOAUTOAIM,0);
				}
			A_StartSound("FireBew",CHAN_6,CHANF_OVERLAP|CHANF_UI,1,false,ATTN_NONE);
				}
		IBEW W 2  
		IBEW I 6 A_TakeInventory("Walpurgisnacht")
		IBEW A 4   
		Goto Ready
	ZoomOverlays:
		Z00M XY 2 
	ZoomOverlays2:
		Z00M Z 1 A_JumpIfInventory ("MaceChargeCheck2", 1, "KillZOverlays") 
		Loop
	KillZOverlays:
		Z00M YX 2 A_TakeInventory("MaceChargeCheck2")
		Stop
	AltFire:
		IBEW A 0 A_JumpIfInventory("Mana1W", 18, "AltCheck")
		IBEW A 0 A_Checkreload
		IBEW A 0 A_WeaponOffset(0,0)
		Goto Fire
	AltCheck:
		IBEW A 0 A_JumpIfInventory("Mana2W", 18, "AltSetup")
		IBEW A 0 A_Checkreload
		Goto Fire
	AltSetup:
		IBEW A 0 A_PlaySound("IchiString",CHAN_6,1.6,false,ATTN_NORM,false,0.9)
		Goto AltFireArrow
	AltFireArrow:
		IBEW A 0 {A_StartSound("BewChargeA",CHAN_5,CHANF_OVERLAP,1.2,false,ATTN_NONE); A_WeaponOffset(0,0);}
		IBEW IJKLN 2 {A_TakeInventory("Mana2W", 3,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 3,TIF_NOTAKEINFINITE);}
		IBEW N 0 {	A_Overlay(23,"AltFireOverlays");
					A_OverlayFlags(23,PSPF_ADDBOB|PSPF_ADDWEAPON,true);}
		IBEW OPQ 3 {A_TakeInventory("Mana2W", 1,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);}
		IBEW R 0 A_Playsound("LBLoop",CHAN_7,0.6,true,ATTN_NONE,false,0.9)
	AltFireHold:
		IBEW R 2  
		IBEW R 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ALTATTACK),"AltFireHold2")
		Goto AltFireRelease
	AltFireHold2:
		IBEW S 2 
		IBEW S 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ALTATTACK),"AltFireHold3")
		Goto AltFireRelease
	AltFireHold3:
		IBEW T 2 
		IBEW T 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_ALTATTACK),"AltFireHold")
		Goto AltFireRelease
	AltFireOverlays:
		VBEW OPQ 3 
	AltFireOverlays2:
		VBEW RR 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillOverlays") //ensure the overlay
		VBEW SS 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillOverlays") //dies if the player
		VBEW TT 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillOverlays") //fires.
		Loop
	KillOverlays:
		VBEW R 2 A_TakeInventory("MaceChargeCheck1")
		Stop
	AltFireRelease:
		IBEW U 0 A_GiveInventory("MaceChargeCheck1",1) //kills the overlay
		IBEW U 2 A_Stopsound(7)
		IBEW W 1 A_SetBlend("Yellow",0.4,20) 
		IBEW W 1 {
			if(CountInv("IchivalUpgrade") == 3 || CountInv("IchivalUpgrade") == 4 || CountInv("IchivalUpgrade") == 8 || CountInv("IchivalUpgrade") == 9)
				{
				A_FireProjectile("ArtilleryArrowOP", 0, 0, 0, 2, FPF_NOAUTOAIM,0);
				}
				else
				{
				A_FireProjectile("ArtilleryArrow", 0, 0, 0, 2, FPF_NOAUTOAIM,0);
				}		
			A_StartSound("FireBew",CHAN_6,CHANF_OVERLAP,1.1,false,ATTN_NONE); 
			A_StartSound("HolyBoom",CHAN_7,CHANF_OVERLAP,1,false,ATTN_NONE);
				}
		IBEW W 2 {if(GetCVar("walp_silentprotagonists")==0 && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExertsHeavy",CHAN_AUTO,CHANF_OVERLAP,0.9,ATTN_NONE,frandom(0.97,1.04));}}
		IBEW I 6 
		IBEW A 4 
		Goto Ready
	Reload:	 
		IBEW A 0 A_JumpIfInventory("Mana1W", 10, "RelCheck")
		IBEW A 0 A_Checkreload
		IBEW A 0 A_WeaponOffset(0,0)
		Goto Fire
	RelCheck:
		IBEW A 0 A_JumpIfInventory("Mana2W", 10, "RelSetup")
		IBEW A 0 A_Checkreload
		Goto Fire
	RelSetup:
		IBEW A 0 A_PlaySound("IchiString",CHAN_6,1.6,false,ATTN_NORM,false,0.9)
		Goto FireComet
	FireComet:
		IBEW A 0 {A_PlaySound("LBRecharge",CHAN_5,1.1,false,ATTN_NORM,false,0.9); A_StartSound("FStormEnd",CHAN_5,CHANF_OVERLAP,0.9,false,ATTN_NONE); A_WeaponOffset(0,0);}
		IBEW IJKL 2 {A_TakeInventory("Mana2W", 1,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 1,TIF_NOTAKEINFINITE);}	
		IBEW N 0 {	A_Overlay(23,"RFireOverlays");
					A_OverlayFlags(23,PSPF_ADDBOB|PSPF_ADDWEAPON,true);}
		IBEW NOP 2 {A_TakeInventory("Mana2W", 2,TIF_NOTAKEINFINITE); A_TakeInventory("Mana1W", 2,TIF_NOTAKEINFINITE);}
		IBEW Q 2 	
		IBEW R 0 A_Playsound("LBLoop",CHAN_7,0.4,true,ATTN_NONE,false,0.9)
	ReloadFireHold:
		IBEW R 2  
		IBEW R 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_RELOAD),"ReloadFireHold2")
		Goto ReloadFireRelease
	ReloadFireHold2:
		IBEW S 2 
		IBEW S 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_RELOAD),"ReloadFireHold3")
		Goto ReloadFireRelease
	ReloadFireHold3:
		IBEW T 2 
		IBEW T 0 A_JumpIf((GetPlayerInput (INPUT_BUTTONS) & BT_RELOAD),"ReloadFireHold")
		Goto ReloadFireRelease
	RFireOverlays:
		ZBEW OPQ 3 
	RFireOverlays2:
		ZBEW RR 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillROverlays") //ensure the overlay
		ZBEW SS 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillROverlays") //dies if the player
		ZBEW TT 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillROverlays") //fires.
		ZBEW UU 1 A_JumpIfInventory ("MaceChargeCheck1", 1, "KillROverlays") 
		Loop
	KillROverlays:
		ZBEW R 2 A_TakeInventory("MaceChargeCheck1")
		Stop
	ReloadFireRelease:
		IBEW U 0 A_GiveInventory("MaceChargeCheck1",1) //kills the overlay
		IBEW U 2 A_Stopsound(7)
		IBEW W 1 A_SetBlend("Yellow",0.4,20)
		IBEW W 1 {
			if(CountInv("IchivalUpgrade") == 5 || CountInv("IchivalUpgrade") == 6 || CountInv("IchivalUpgrade") == 8 || CountInv("IchivalUpgrade") == 9)
				{
				A_FireProjectile("BounceArrowPlus", 0, 0, 0, 2, FPF_NOAUTOAIM,0);
				}
				else
				{
				A_FireProjectile("BounceArrow", 0, 0, 0, 2, FPF_NOAUTOAIM,0);
				}
			A_StartSound("FireBew",CHAN_6,CHANF_OVERLAP,1,false,ATTN_NONE);  
			A_StartSound("GoodnessGracious",CHAN_6,CHANF_OVERLAP,1,false,ATTN_NONE); //GOODNEZZ GRASHUSSH GREAT-BALLZ O FAYAAA!!
				}
		IBEW W 2 {if(GetCVar("walp_silentprotagonists")==0 && (CountInv("PowerShutItWilson")) == 0)
		{A_StartSound("DruiExerts",CHAN_AUTO,CHANF_OVERLAP,0.9,ATTN_NONE,frandom(0.97,1.04));}}
		IBEW I 6 
		IBEW A 4 
		Goto Ready
	}
}

ACTOR LightArrow : FastProjectile
{ 
	Obituary "%o was burned alive by %k's purification arrows." 
	Radius 7 
	Height 6 
	Speed 132
	Scale 0.55
	Damage 4
	Damagetype "Sacred"
	MissileType "SunProjectileTrail" 
	MissileHeight 8
	Renderstyle Add
	Projectile
	Decal "SerpentScorch"
	+CANBOUNCEWATER
	+FORCEXYBILLBOARD
	+FORCERADIUSDMG
	+ACTIVATEIMPACT
	+MTHRUSPECIES 
	+DONTBLAST
	+NOTIMEFREEZE
	+ROLLSPRITE
	+ROLLCENTER
	alpha 1.0
	SeeSound "CruxShots"
	States 
	{ 
	Spawn:
		L4R0 ABCDEFGHI 2 Bright 
		Loop
	Death: 
		YGLW A 0 
		{
		A_Stop;
		//A_Explode(random(195,260)+random(2,8),212,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,170,0,0,FireActive,"Blast"); // Original line
		A_Explode(random(195,260)+random(2,8),128,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,32,0,0,FireActive,"Blast");
		A_SetScale(0.6,0.6);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		}
		TNT1 A 0 A_SpawnItemEx("PostBurstLightArrowz",-9,0,0,-1,0,0)
		Stop
	} 
}

Actor PostBurstLightArrowz 
{
 +NOGRAVITY
 +NOCLIP
 +NOINTERACTION
 +FORCEXYBILLBOARD
 +ROLLSPRITE
 +ROLLCENTER
 -SOLID
 Radius 0
 Height 0
 RenderStyle Add
 Alpha 1.0
 Scale 0.6
 States
 {
  Spawn:
   TNT1 A 0 Bright Nodelay A_Setroll(roll+random(-22,22))
   TNT1 AAAAAAAA 0 {A_SpawnItemEx("YellowCruxTrail2",random(-20,20),random(-20,20),1,random(-4,-18),random(-12,12),random(4,9));
				A_SpawnItemEx("YellowCruxTrail2",random(-20,20),random(-20,20),1,random(-4,-18),random(-12,12),random(4,9));}
   L4R0 JKLMNO 2 Bright {A_Fadeout(0.1); A_SetScale(scalex+0.18,scaley+0.18); A_Setroll(roll+random(11,22));}
   Stop
 }
}

ACTOR LightArrowPlus : LightArrow //upgraded prumary fire  
{
	Damage 6
	+HITTRACER
	States 
	{ 
	Spawn:
		L4R0 ABCDEFGHI 2 Bright A_SpawnItemEx("YellowSparklies2",random(25,35)* cos(pitch),random(10,25),(random(26,30) - (40 * sin(pitch))),velx,vely,velz+0.3)
		Loop
	Death: 
		YGLW A 0 
		{
		A_Stop;
		//A_Explode(random(195,260)+random(2,8),212,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Blast"); // Original line
		A_Explode(random(195,260)+random(2,8),128,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,64,0,0,FireActive,"Blast");
		A_SetScale(0.6,0.6);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		}
		TNT1 A 0 A_SpawnItemEx("PostBurstLightArrowz",-9,0,0,-1,0,0)
		Stop
	} 
}

ACTOR MIRVArrow : LightArrow //The core part of secondary fire
{
	Speed 95
	Damage 1
	+FRIENDLY
	States 
	{
	Spawn:
		TNT1 A 0
		LARO A 0 
		Goto Spawn2
	Spawn2:
		L4R0 ABCDEFGHI 2 Bright 
		Loop
	Death: 
		YGLW A 0 
		{
		A_Stop;
		A_Explode(random(35,65)+random(2,8),188,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Light");
		A_SetScale(1.2,1.2);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		}
		YGLW AAAAAAAAAAA 2 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}
		Stop
	} 
}

ACTOR MIRVArrowPlus : MIRVArrow //upgraded Artillery Arrow piece for insane chaos.
{
	+HEXENBOUNCE
	BounceFactor 0.1
	BounceCount 1
	States
	{
	Death: 
		YGLW A 0 
		{
		A_Stop;
		A_Explode(random(35,65)+random(2,8),188,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Light");
		A_SetScale(1.2,1.2);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		A_SpawnProjectile("CalicusShotIchival", 0, 0, random(95, 270), CMF_AIMDIRECTION, random(-10, 30));
		}
		YGLW AAAAAAAAAAA 2 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}
		Stop
	Crash: 
		YGLW A 0 
		{
		A_Stop;
		A_Explode(random(35,65)+random(2,8),188,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Light");
		A_SetScale(1.2,1.2);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		A_SpawnProjectile("CalicusShotIchival", 0, 0, random(95, 270), CMF_AIMDIRECTION, random(-10, 30));
		}
		YGLW AAAAAAAAAAA 2 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}
		Stop
	}
}

ACTOR ArtilleryArrow : MIRVArrow //Spawns MIRVArrow as it travels.
{
	+EXTREMEDEATH
	States 
	{ 
	Spawn:
		LARO A 0 
		LARO A 0 {	A_FaceMovementDirection(0,180,180); //important to stop it acting wonky.
					A_Playsound("BlazeTrail",CHAN_7,1,true,ATTN_NORM,false,0.9);}
	Spawn2:
		L4R0 ABCDEFGHI 2 Bright {
			A_GiveInventory("Mana2",1); //As it travels, it spits out multiple MIRV arrows for a crazy wave of devastation
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,25*(CountInv("Mana2")) ,25*(CountInv("Mana2"))-(sin(pitch)*25)	,cos(pitch)*80,0+((CountInv("Mana2")*2)),-sin(pitch)*80-((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,-25*(CountInv("Mana2")),-25*(CountInv("Mana2"))-(sin(pitch)*25)	,cos(pitch)*80,0-((CountInv("Mana2")*2)),-sin(pitch)*80+((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,25*(CountInv("Mana2")) ,-25*(CountInv("Mana2"))-(sin(pitch)*25)	,cos(pitch)*80,0-((CountInv("Mana2")*2)),-sin(pitch)*80-((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,-25*(CountInv("Mana2")),25*(CountInv("Mana2"))-(sin(pitch)*25)	,cos(pitch)*80,0+((CountInv("Mana2")*2)),-sin(pitch)*80+((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,0					   ,35*(CountInv("Mana2"))-(sin(pitch)*35)	,cos(pitch)*80,0+((CountInv("Mana2")*2)),-sin(pitch)*80,0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,0					   ,-35*(CountInv("Mana2"))-(sin(pitch)*35)	,cos(pitch)*80,0-((CountInv("Mana2")*2)),-sin(pitch)*80,0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,-35*(CountInv("Mana2")),(sin(pitch)*35)							,cos(pitch)*80,0,-sin(pitch)*80+((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );
			A_SpawnItemEx("MIRVArrow",cos(pitch)*-5,35*(CountInv("Mana2")) ,(sin(pitch)*35)							,cos(pitch)*80,0,-sin(pitch)*80-((CountInv("Mana2")*2)),0,SXF_ORIGINATOR|SXF_SETMASTER|SXF_TRANSFERPITCH );	
			A_SetRoll(roll+(CountInv("Mana2")));
			}
		Loop
	Death: 
		YGLW A 0 
		{
		A_Stop;
		A_Stopsound(7);
		A_Explode(random(35,65)+random(2,8),188,XF_THRUSTZ|XF_EXPLICITDAMAGETYPE,true,80,0,0,FireActive,"Light");
		A_SetScale(1.2,1.2);
		A_PlaySound("HolyBooms",CHAN_6,1.1,false,ATTN_NORM,false,0.9);
		}
		YGLW AAAAAAAAAAA 2 Bright {A_SetScale(scalex+0.15,scaley+0.15); A_Fadeout(0.1); A_Setroll(roll+random(22,44));}
		Stop
	}
}

